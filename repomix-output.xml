    // NEU: Triggert den neuen Befehl im Reducer!
    dispatch({ type: 'RECORD_SHOCK', payload: joule }); 
    dispatch({ type: 'SET_PHASE', payload: CPR_CONFIG.PHASES.WAITING_CPR_RESUME });
