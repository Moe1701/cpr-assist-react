      )}

      {/* Die Container-Breite sorgt dafür, dass nichts den Kreis berührt */}
      <div className="w-[85%] max-w-[220px] flex flex-col gap-2">
        
        {/* BEUTEL-MASKE: Weiß mit Cyan Rahmen */}
