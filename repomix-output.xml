      return <ViewObAnalyze />;
    case CPR_CONFIG.PHASES.DECISION:           
      return <ViewDecision />;
    case CPR_CONFIG.PHASES.JOULE:              
      return <ViewJoule />;
    case CPR_CONFIG.PHASES.WAITING_CPR_RESUME: 
      return <ViewCprResume />;
    default:                   
      return null;
  }
}
